# PostgreSQL connection for Prisma migrate / generate / seed.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/struxient_v3?schema=public"

# Local Docker example (matches optional dev container name struxient-pg):
# DATABASE_URL="postgresql://struxient:struxient@localhost:5432/struxient_v3"

# NextAuth / Auth.js — required for credentials sessions (generate: openssl rand -base64 32)
AUTH_SECRET="replace-with-random-secret"

# Next.js dev: auto-written to .env.local by `npm run db:seed` (restart dev server after seed)
# STRUXIENT_DEV_TENANT_ID="…"
# STRUXIENT_DEV_QUOTE_VERSION_ID="…"
# STRUXIENT_DEV_USER_ID="…"
# After `npm run db:seed:activated` (send → sign → activate smoke path):
# STRUXIENT_DEV_FLOW_ID="…"
# STRUXIENT_DEV_JOB_ID="…"
# Optional stable send idempotency key for the script (default: struxient-seed-activated-path):
# STRUXIENT_DEV_SEND_CLIENT_REQUEST_ID="…"
#
# Skip writing .env.local (e.g. CI): STRUXIENT_SEED_SKIP_DEV_ENV=1
# Skip copying DATABASE_URL into .env.local during seed: STRUXIENT_SEED_SKIP_DATABASE_URL_MIRROR=1

# Seed user password for credentials login (default if unset: struxient-dev)
# STRUXIENT_SEED_DEV_PASSWORD="…"

# Local-only: skip NextAuth and use env user+tenant after DB verification (ignored when NODE_ENV=production)
# STRUXIENT_DEV_AUTH_BYPASS=true

# Legacy unauthenticated tenant resolution (API routes no longer use this for the spine):
# Never enable in real production unless you understand the risk:
# STRUXIENT_ALLOW_TENANT_HEADER=true

# Tenant policy is stored on the row: `Tenant.autoActivateOnSign` (boolean, default false).
# When true, POST …/sign runs activation in the same DB transaction; see implementation reports.

# Absolute public origin for customer portal links in office UI / comms bodies (optional; else derived from request headers).
# STRUXIENT_PUBLIC_APP_ORIGIN="https://app.example.com"

# Integration smoke (npm run test:integration): URL of running Next server (default http://127.0.0.1:3000)
# INTEGRATION_BASE_URL="http://127.0.0.1:3000"
# CI: GitHub Actions runs migrate → seed → build → start → `npm run test:integration` (see .github/workflows/integration-smoke.yml).
# After `next start`, `npm run ci:wait-for-app` polls /api/auth/providers (same as the workflow wait step).
# After db:seed:activated, STRUXIENT_DEV_FLOW_ID enables field/skeleton success assertions in the suite.

# --- Storage Provider ---
# Values: DISK (default), S3
# STRUXIENT_STORAGE_PROVIDER=S3
# FILE_STORAGE_PATH="./storage" # Default for DISK provider

# --- S3 Configuration (only if provider is S3) ---
# STRUXIENT_S3_BUCKET="my-bucket"
# STRUXIENT_S3_REGION="us-east-1"
# STRUXIENT_S3_ACCESS_KEY_ID="replace-me"
# STRUXIENT_S3_SECRET_ACCESS_KEY="replace-me"
# STRUXIENT_S3_ENDPOINT="http://localhost:9000" # For Minio/S3-compatible
# STRUXIENT_S3_FORCE_PATH_STYLE=true # For Minio
