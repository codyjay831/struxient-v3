// Struxient v3 — Slice 1 relational foundation + extension (PreJobTask, QuoteLocalPacket).
// Merge basis: docs/schema-slice-1-codepack/03-prisma-schema-draft-v0.md
// Extension: docs/implementation/schema/slice-1-extension-prejobtask-quotelocalpacket.md
//
// Invariants not fully expressible in Prisma (enforce in app / raw SQL):
// - PreJobTask.tenantId must equal flowGroup.tenantId; if quoteVersionId set, quote must belong to same flowGroup.
// - QuoteLocalPacket.tenantId must match quoteVersion.quote.tenantId.
// - Manifest QuoteLineItem: exactly one of (scopePacketRevisionId, quoteLocalPacketId) — see migration CHECK.
// Service-layer assertions: src/server/slice1/invariants/ (+ getQuoteVersionScopeReadModel read path).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QuoteVersionStatus {
  DRAFT
  SENT
  SIGNED
  /// Customer declined via portal (Epic 13 + 54); frozen payloads retained; not signable.
  DECLINED
  /// Withdrawn by office; frozen payloads retained; not signable (Epic 14).
  VOID
  /// Prior sent proposal replaced when a newer version was sent; portal link inactive (Epic 14).
  SUPERSEDED
}

enum ScopePacketRevisionStatus {
  DRAFT
  PUBLISHED
  SUPERSEDED
}

enum WorkflowVersionStatus {
  DRAFT
  PUBLISHED
  /// Prior published row demoted when a newer version is published (Epic 23 lifecycle).
  SUPERSEDED
}

enum PacketTaskLineKind {
  EMBEDDED
  LIBRARY
}

enum QuoteLineItemExecutionMode {
  SOLD_SCOPE
  MANIFEST
}

enum AuditEventType {
  QUOTE_VERSION_SENT
  QUOTE_VERSION_SIGNED
  /// Customer declined a sent quote via portal share token (Epic 13 + 54).
  QUOTE_VERSION_DECLINED_PORTAL
  QUOTE_VERSION_ACTIVATED
  FLOW_SHARE_MANAGED
  FLOW_SHARE_DELIVERED
  PROJECT_SHARE_DELIVERED
  PROJECT_SHARE_MANAGED
  QUOTE_PORTAL_SHARE_DELIVERED
  QUOTE_PORTAL_LINK_REGENERATED
  QUOTE_VERSION_VOIDED
  QUOTE_VERSION_SUPERSEDED
  /// Epic 44 — office briefed field; does not mutate scope/freeze.
  JOB_HANDOFF_SENT
  JOB_HANDOFF_ACKNOWLEDGED
  /// Epic 06 — office customer file row (not task evidence).
  CUSTOMER_DOCUMENT_UPLOADED
  CUSTOMER_DOCUMENT_ARCHIVED
  /// Epic 57 — customer CRM surface (not user-authored note bodies in payload).
  CUSTOMER_NOTE_CREATED
  CUSTOMER_NOTE_UPDATED
  CUSTOMER_NOTE_ARCHIVED
  CUSTOMER_CONTACT_CREATED
  CUSTOMER_CONTACT_UPDATED
  CUSTOMER_CONTACT_ARCHIVED
  CUSTOMER_CONTACT_METHOD_CHANGED
  /// Epic 60 — tenant operational policy (no entity FK; payload only).
  TENANT_OPERATIONAL_SETTINGS_UPDATED
  /// Epic 59 — `User.role` change within tenant (office admin).
  TENANT_MEMBER_ROLE_UPDATED
}

/// Epic 06 — coarse document kind for office customer files (not a full taxonomy).
enum CustomerDocumentCategory {
  DOCUMENT
  IMAGE
  OTHER
}

enum CustomerDocumentStatus {
  ACTIVE
  ARCHIVED
}

/// Epic 44 — office-to-field briefing record (intent only; not scheduling authority).
enum JobHandoffStatus {
  DRAFT
  SENT
  ACKNOWLEDGED
}

enum PublicShareDeliveryMethod {
  EMAIL
  SMS
  MANUAL_LINK
}

enum PublicShareDeliveryStatus {
  QUEUED
  SENDING
  SENT
  FAILED
}

enum ChangeOrderStatus {
  DRAFT
  PENDING_CUSTOMER
  READY_TO_APPLY
  APPLIED
  VOID
}

enum PublicShareStatus {
  UNPUBLISHED
  PUBLISHED
}

enum PaymentGateStatus {
  UNSATISFIED
  SATISFIED
}

/// Operational overlay holds (Epic 29 / 48 backbone). Distinct from `PaymentGate` rows.
enum HoldStatus {
  ACTIVE
  RELEASED
}

/// First slice: single office-authored operational type; payment-linked holds deferred.
enum HoldType {
  OPERATIONAL_CUSTOM
}

enum TaskExecutionTaskKind {
  RUNTIME
  SKELETON
}

enum TaskExecutionEventType {
  STARTED
  COMPLETED
  REVIEW_ACCEPTED
  CORRECTION_REQUIRED
}

enum QuoteSignatureMethod {
  OFFICE_RECORDED
  /// Customer self-service acceptance via `QuoteVersion.portalQuoteShareToken` (Epic 54).
  CUSTOMER_PORTAL_ACCEPTED
}

enum PreJobTaskStatus {
  OPEN
  READY
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

/// Epic 04 foundation — person record on a Customer (office-scoped; not polymorphic yet).
enum CustomerContactRole {
  BILLING
  SITE
  OWNER
  OTHER
}

enum CustomerContactMethodType {
  EMAIL
  PHONE
  MOBILE
  OTHER
}

enum QuoteLocalPacketOrigin {
  FORK_FROM_LIBRARY
  AI_DRAFT
  MANUAL_LOCAL
}

enum QuoteLocalPromotionStatus {
  NONE
  REQUESTED
  IN_REVIEW
  REJECTED
  COMPLETED
}

enum QuoteLocalPacketLineKind {
  EMBEDDED
  LIBRARY
}

/// Minimal catalog row so QuoteLocalPacketItem can reference LIBRARY lines (extension doc).
/// Full TaskDefinition shape deferred to epic 17; expand fields in a follow-up migration.
enum TaskDefinitionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/// Tenant-scoped authorization shell (v3 auth slice). Enforced in API layer; not a full IAM matrix.
enum TenantMemberRole {
  OFFICE_ADMIN
  FIELD_WORKER
  READ_ONLY
}

/// Epic 01 — minimal lead pipeline before quote shell (conversion-first MVP; no CRM sub-tables in this slice).
enum LeadStatus {
  OPEN
  ON_HOLD
  NURTURE
  LOST
  ARCHIVED
  CONVERTED
}

model Tenant {
  id                       String   @id @default(cuid())
  name                     String
  /// When true, successful POST …/sign (non-replay) runs activation in the same transaction (`epic 33`).
  autoActivateOnSign       Boolean  @default(false)
  /// Max single **office** customer document upload (bytes); clamped server-side to platform min/ceiling (Epic 60).
  customerDocumentMaxBytes Int      @default(20971520)
  createdAt                DateTime @default(now())

  users                      User[]
  customers                  Customer[]
  flowGroups                 FlowGroup[]
  scopePackets               ScopePacket[]
  workflowTemplates          WorkflowTemplate[]
  quotes                     Quote[]
  auditEvents                AuditEvent[]
  taskDefinitions            TaskDefinition[]
  jobs                       Job[]
  quoteSignatures            QuoteSignature[]
  flows                      Flow[]
  activations                Activation[]
  runtimeTasks               RuntimeTask[]
  taskExecutions             TaskExecution[]
  paymentGates               PaymentGate[]
  changeOrders               ChangeOrder[]
  completionProofs           CompletionProof[]
  completionProofAttachments CompletionProofAttachment[]
  flowShareDeliveries        FlowShareDelivery[]
  projectShareDeliveries     ProjectShareDelivery[]
  quotePortalShareDeliveries QuotePortalShareDelivery[]
  customerContacts           CustomerContact[]
  customerNotes              CustomerNote[]
  customerDocuments          CustomerDocument[]
  jobHandoffs                JobHandoff[]
  holds                      Hold[]
  leads                      Lead[]
}

model User {
  id           String           @id @default(cuid())
  tenantId     String
  email        String
  displayName  String?
  /// bcrypt hash for credentials auth; null until set (e.g. legacy rows).
  passwordHash String?
  role         TenantMemberRole @default(OFFICE_ADMIN)
  createdAt    DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  quoteVersionsCreated    QuoteVersion[]   @relation("QuoteVersionCreatedBy")
  quoteVersionsSent       QuoteVersion[]   @relation("QuoteVersionSentBy")
  quoteVersionsSigned     QuoteVersion[]   @relation("QuoteVersionSignedBy")
  quoteSignaturesRecorded QuoteSignature[] @relation("QuoteSignatureRecordedBy")
  auditEvents             AuditEvent[]
  activationsActivated    Activation[]     @relation("ActivationActivatedBy")
  taskExecutions          TaskExecution[]

  preJobTasksAssigned PreJobTask[] @relation("PreJobTaskAssignee")
  preJobTasksCreated  PreJobTask[] @relation("PreJobTaskCreator")

  paymentGatesSatisfied PaymentGate[] @relation("PaymentGateSatisfiedBy")

  changeOrdersCreated ChangeOrder[] @relation("ChangeOrderCreatedBy")
  changeOrdersApplied ChangeOrder[] @relation("ChangeOrderAppliedBy")

  holdsCreated  Hold[] @relation("HoldCreatedBy")
  holdsReleased Hold[] @relation("HoldReleasedBy")

  completionProofAttachments CompletionProofAttachment[] @relation("CompletionProofAttachmentCreatedBy")

  quoteLocalPacketsCreated   QuoteLocalPacket[]         @relation("QuoteLocalPacketCreatedBy")
  quoteLocalPacketsUpdated   QuoteLocalPacket[]         @relation("QuoteLocalPacketUpdatedBy")
  quotePortalShareDeliveries QuotePortalShareDelivery[] @relation("QuotePortalShareDeliveredBy")
  quoteVersionsVoided        QuoteVersion[]             @relation("QuoteVersionVoidedBy")
  flowShareDeliveries        FlowShareDelivery[]
  projectShareDeliveries     ProjectShareDelivery[]

  customerNotesCreated CustomerNote[] @relation("CustomerNoteCreatedBy")

  customerDocumentsUploaded CustomerDocument[] @relation("CustomerDocumentUploadedBy")

  jobHandoffsCreated      JobHandoff[] @relation("JobHandoffCreatedBy")
  jobHandoffsSent         JobHandoff[] @relation("JobHandoffSentBy")
  jobHandoffsAcknowledged JobHandoff[] @relation("JobHandoffAcknowledgedBy")

  leadsCreated  Lead[] @relation("LeadCreatedBy")
  leadsAssigned Lead[] @relation("LeadAssignedTo")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model TaskDefinition {
  id          String               @id @default(cuid())
  tenantId    String
  taskKey     String
  displayName String
  status      TaskDefinitionStatus @default(DRAFT)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  instructions               String?
  /// Durable authored shape; see src/lib/task-definition-authored-requirements.ts.
  /// Array of:
  ///   { kind: 'checklist'   , label: string,                    required: boolean }
  ///   { kind: 'measurement' , label: string, unit?: string,     required: boolean }
  ///   { kind: 'identifier'  , label: string,                    required: boolean }
  ///   { kind: 'result'      ,                                   required: boolean }   // singleton (overall PASS/FAIL)
  ///   { kind: 'note'        ,                                   required: boolean }   // singleton (completion note)
  ///   { kind: 'attachment'  ,                                   required: boolean }   // singleton (photo/evidence proof)
  completionRequirementsJson Json?
  /// Array of conditional rules that require additional evidence based on outcomes; see conditional-completion-rules-backbone-pass.md.
  conditionalRulesJson       Json?

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  quoteLocalPacketItems QuoteLocalPacketItem[]
  packetTaskLines       PacketTaskLine[]

  @@unique([tenantId, taskKey])
  @@index([tenantId])
}

model Customer {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  primaryEmail       String?
  primaryPhone       String?
  billingAddressJson Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  flowGroups          FlowGroup[]
  quotes              Quote[]
  contacts            CustomerContact[]
  notes               CustomerNote[]
  documents           CustomerDocument[]
  auditEventsTargeted AuditEvent[]       @relation("AuditEventTargetCustomer")
  leadsConvertedFrom  Lead[]             @relation("LeadConvertedCustomer")

  @@index([tenantId])
}

/// Office-attached file on a **Customer** (Epic 06); not completion evidence — separate from `CompletionProofAttachment`.
model CustomerDocument {
  id           String                   @id @default(cuid())
  tenantId     String
  customerId   String
  storageKey   String                   @unique
  fileName     String
  contentType  String
  sizeBytes    Int
  category     CustomerDocumentCategory @default(OTHER)
  caption      String?
  status       CustomerDocumentStatus   @default(ACTIVE)
  archivedAt   DateTime?
  uploadedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  uploadedBy User     @relation("CustomerDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([tenantId, customerId])
  @@index([customerId, createdAt])
}

/// Office-authored note on a Customer (not `AuditEvent`; not a merged timeline yet).
model CustomerNote {
  id          String    @id @default(cuid())
  tenantId    String
  customerId  String
  body        String
  archivedAt  DateTime?
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  createdBy User     @relation("CustomerNoteCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, customerId])
  @@index([customerId, createdAt])
}

/// Person + methods anchored to a Customer (tenant matches Customer.tenantId).
model CustomerContact {
  id          String               @id @default(cuid())
  tenantId    String
  customerId  String
  displayName String
  role        CustomerContactRole?
  notes       String?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer Customer                @relation(fields: [customerId], references: [id], onDelete: Restrict)
  methods  CustomerContactMethod[]

  @@index([tenantId, customerId])
  @@index([customerId])
}

model CustomerContactMethod {
  id        String                    @id @default(cuid())
  contactId String
  type      CustomerContactMethodType
  value     String
  /// Customer-wide per `type`; mutations demote other primaries on all contacts for that customer (Epic 04).
  isPrimary Boolean                   @default(false)
  okToSms   Boolean                   @default(false)
  okToEmail Boolean                   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact CustomerContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
}

/// Office-initiated delivery of a **quote** customer-portal link (Epic 54); mirrors `FlowShareDelivery` shape.
model QuotePortalShareDelivery {
  id              String                    @id @default(cuid())
  tenantId        String
  quoteVersionId  String
  deliveredAt     DateTime                  @default(now())
  deliveredById   String
  deliveryMethod  PublicShareDeliveryMethod
  recipientDetail String?
  shareToken      String

  providerStatus     PublicShareDeliveryStatus @default(QUEUED)
  providerExternalId String?
  providerError      String?
  providerResponse   Json?
  retryCount         Int                       @default(0)
  isFollowUp         Boolean                   @default(false)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  quoteVersion QuoteVersion @relation(fields: [quoteVersionId], references: [id], onDelete: Cascade)
  deliveredBy  User         @relation("QuotePortalShareDeliveredBy", fields: [deliveredById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([quoteVersionId])
}

model FlowShareDelivery {
  id              String                    @id @default(cuid())
  tenantId        String
  flowId          String
  deliveredAt     DateTime                  @default(now())
  deliveredById   String
  deliveryMethod  PublicShareDeliveryMethod
  recipientDetail String? // Email or phone number
  shareToken      String // Snapshot of token at delivery time

  providerStatus     PublicShareDeliveryStatus @default(QUEUED)
  providerExternalId String?
  providerError      String?
  providerResponse   Json?
  retryCount         Int                       @default(0)
  isFollowUp         Boolean                   @default(false)

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  flow        Flow   @relation(fields: [flowId], references: [id], onDelete: Restrict)
  deliveredBy User   @relation(fields: [deliveredById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([flowId])
}

model FlowGroup {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  name       String
  createdAt  DateTime @default(now())

  publicShareToken            String?           @unique @default(cuid())
  publicShareStatus           PublicShareStatus @default(UNPUBLISHED)
  publicShareTokenGeneratedAt DateTime?
  publicShareExpiresAt        DateTime?

  publicShareFirstViewedAt DateTime?
  publicShareLastViewedAt  DateTime?
  publicShareViewCount     Int       @default(0)

  publicShareReceiptAcknowledgedAt DateTime?

  publicShareClarificationRequestedAt    DateTime?
  publicShareClarificationReason         String?
  publicShareClarificationResolvedAt     DateTime?
  publicShareClarificationResolutionNote String?
  publicShareClarificationEscalatedAt    DateTime?

  publicShareNotificationLastSeenAt DateTime?

  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer           Customer               @relation(fields: [customerId], references: [id], onDelete: Restrict)
  quotes             Quote[]
  preJobTasks        PreJobTask[]
  job                Job?
  deliveries         ProjectShareDelivery[]
  leadsConvertedFrom Lead[]                 @relation("LeadConvertedFlowGroup")

  @@index([tenantId])
  @@index([customerId])
}

/// Minimal prospective-opportunity row (Epic 01). Intake spine remains Customer → FlowGroup → quote shell; app reads/mutations not in this slice.
model Lead {
  id           String     @id @default(cuid())
  tenantId     String
  displayName  String
  status       LeadStatus @default(OPEN)
  source       String?
  primaryEmail String?
  primaryPhone String?
  summary      String?

  assignedToUserId String?
  createdById      String

  lostReason String?

  convertedAt          DateTime?
  convertedCustomerId  String?
  convertedFlowGroupId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignedTo User?  @relation("LeadAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy  User   @relation("LeadCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  convertedCustomer  Customer?  @relation("LeadConvertedCustomer", fields: [convertedCustomerId], references: [id], onDelete: SetNull)
  convertedFlowGroup FlowGroup? @relation("LeadConvertedFlowGroup", fields: [convertedFlowGroupId], references: [id], onDelete: SetNull)

  quotes Quote[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, createdAt])
}

model PreJobTask {
  id             String  @id @default(cuid())
  tenantId       String
  flowGroupId    String
  quoteVersionId String?

  taskType   String
  sourceType String

  title       String
  description String?

  assignedToUserId String?
  createdById      String

  dueAt            DateTime?
  scheduledStartAt DateTime?
  scheduledEndAt   DateTime?

  status       PreJobTaskStatus
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flowGroup      FlowGroup     @relation(fields: [flowGroupId], references: [id], onDelete: Restrict)
  quoteVersion   QuoteVersion? @relation(fields: [quoteVersionId], references: [id], onDelete: SetNull)
  assignedToUser User?         @relation("PreJobTaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  createdBy      User          @relation("PreJobTaskCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, flowGroupId, status])
  @@index([tenantId, assignedToUserId, status])
}

model ScopePacket {
  id          String @id @default(cuid())
  tenantId    String
  packetKey   String
  displayName String

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  revisions ScopePacketRevision[]

  @@unique([tenantId, packetKey])
  @@index([tenantId])
}

model ScopePacketRevision {
  id             String                    @id @default(cuid())
  scopePacketId  String
  revisionNumber Int
  status         ScopePacketRevisionStatus
  /// Nullable for DRAFT revisions produced by the interim one-step promotion flow.
  /// Required for PUBLISHED rows; service-layer enforces the conditional.
  /// Canon: docs/canon/05-packet-canon.md, docs/implementation/decision-packs/interim-packet-promotion-decision-pack.md.
  publishedAt    DateTime?

  scopePacket     ScopePacket      @relation(fields: [scopePacketId], references: [id], onDelete: Restrict)
  packetTaskLines PacketTaskLine[]
  quoteLineItems  QuoteLineItem[]

  quoteLocalPacketsForkedFromThis QuoteLocalPacket[] @relation("QuoteLocalPacketForkSource")

  @@unique([scopePacketId, revisionNumber])
  @@index([scopePacketId])
  @@index([status])
}

model PacketTaskLine {
  id                    String             @id @default(cuid())
  scopePacketRevisionId String
  lineKey               String
  tierCode              String?
  sortOrder             Int
  lineKind              PacketTaskLineKind
  embeddedPayloadJson   Json
  taskDefinitionId      String?

  /// Top-level required column (canon amendment for interim promotion slice).
  /// Mirrors QuoteLocalPacketItem.targetNodeKey to enable 1:1 promotion mapping.
  /// Canon: docs/canon/05-packet-canon.md, docs/epics/16-packet-task-lines-epic.md §6 + §16a.
  targetNodeKey String

  scopePacketRevision ScopePacketRevision @relation(fields: [scopePacketRevisionId], references: [id], onDelete: Restrict)
  taskDefinition      TaskDefinition?     @relation(fields: [taskDefinitionId], references: [id], onDelete: SetNull)

  @@unique([scopePacketRevisionId, lineKey])
  @@index([scopePacketRevisionId])
}

model WorkflowTemplate {
  id          String @id @default(cuid())
  tenantId    String
  templateKey String
  displayName String

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  versions WorkflowVersion[]

  @@unique([tenantId, templateKey])
  @@index([tenantId])
}

model WorkflowVersion {
  id                          String                @id @default(cuid())
  workflowTemplateId          String
  versionNumber               Int
  status                      WorkflowVersionStatus
  /// Set when status is PUBLISHED or SUPERSEDED; null for honest DRAFT rows (Epic 23).
  publishedAt                 DateTime?
  snapshotJson                Json
  /// When this DRAFT was created via fork-from-published/superseded; immutable lineage pointer (Epic 23).
  forkedFromWorkflowVersionId String?

  workflowTemplate    WorkflowTemplate @relation(fields: [workflowTemplateId], references: [id], onDelete: Restrict)
  pinnedQuoteVersions QuoteVersion[]
  flows               Flow[]

  forkedFromWorkflowVersion WorkflowVersion?  @relation("WorkflowVersionForkLineage", fields: [forkedFromWorkflowVersionId], references: [id], onDelete: SetNull)
  forkLineageChildren       WorkflowVersion[] @relation("WorkflowVersionForkLineage")

  @@unique([workflowTemplateId, versionNumber])
  @@index([workflowTemplateId])
  @@index([status])
  @@index([forkedFromWorkflowVersionId])
}

model Job {
  id          String   @id @default(cuid())
  tenantId    String
  flowGroupId String   @unique
  createdAt   DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  flowGroup    FlowGroup     @relation(fields: [flowGroupId], references: [id], onDelete: Restrict)
  flows        Flow[]
  activations  Activation[]
  paymentGates PaymentGate[]
  changeOrders ChangeOrder[]
  holds        Hold[]
  jobHandoff   JobHandoff?

  @@index([tenantId])
}

model Flow {
  id                String   @id @default(cuid())
  tenantId          String
  jobId             String
  workflowVersionId String
  quoteVersionId    String   @unique
  createdAt         DateTime @default(now())

  publicShareToken            String?           @unique @default(cuid())
  publicShareStatus           PublicShareStatus @default(UNPUBLISHED)
  publicShareTokenGeneratedAt DateTime?

  publicShareFirstViewedAt      DateTime?
  publicShareLastViewedAt       DateTime?
  publicShareViewCount          Int       @default(0)
  publicShareLastFollowUpSentAt DateTime?

  publicShareReceiptAcknowledgedAt       DateTime?
  publicShareClarificationRequestedAt    DateTime?
  publicShareClarificationReason         String?
  publicShareClarificationResolvedAt     DateTime?
  publicShareClarificationResolutionNote String?

  publicShareNotificationLastSeenAt DateTime?

  publicShareExpiresAt DateTime?

  auditEvents AuditEvent[]
  deliveries  FlowShareDelivery[]

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  job             Job             @relation(fields: [jobId], references: [id], onDelete: Restrict)
  workflowVersion WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Restrict)
  quoteVersion    QuoteVersion    @relation(fields: [quoteVersionId], references: [id], onDelete: Restrict)
  activation      Activation?
  runtimeTasks    RuntimeTask[]
  taskExecutions  TaskExecution[]

  @@index([tenantId])
  @@index([jobId])
}

model TaskExecution {
  id             String                 @id @default(cuid())
  tenantId       String
  flowId         String
  taskKind       TaskExecutionTaskKind
  runtimeTaskId  String?
  skeletonTaskId String?
  eventType      TaskExecutionEventType
  actorUserId    String
  notes          String?
  createdAt      DateTime               @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  flow        Flow         @relation(fields: [flowId], references: [id], onDelete: Restrict)
  actor       User         @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  runtimeTask RuntimeTask? @relation(fields: [runtimeTaskId], references: [id], onDelete: Restrict)

  completionProof CompletionProof? @relation("TaskExecutionToCompletionProof")

  @@index([runtimeTaskId])
  @@index([tenantId, flowId])
  @@index([flowId, createdAt])
}

model Activation {
  id                    String   @id @default(cuid())
  tenantId              String
  quoteVersionId        String   @unique
  jobId                 String
  flowId                String   @unique
  packageSnapshotSha256 String
  activatedAt           DateTime @default(now())
  activatedById         String

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  quoteVersion QuoteVersion @relation(fields: [quoteVersionId], references: [id], onDelete: Restrict)
  job          Job          @relation(fields: [jobId], references: [id], onDelete: Restrict)
  flow         Flow         @relation(fields: [flowId], references: [id], onDelete: Restrict)
  activatedBy  User         @relation("ActivationActivatedBy", fields: [activatedById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([jobId])
}

model RuntimeTask {
  id             String   @id @default(cuid())
  tenantId       String
  flowId         String
  packageTaskId  String
  nodeId         String
  quoteVersionId String
  lineItemId     String
  planTaskIds    Json
  displayTitle   String
  createdAt      DateTime @default(now())

  /// Snapshot of TaskDefinition.completionRequirementsJson (or embedded payload) frozen at activation.
  /// Same authored shape; see src/lib/task-definition-authored-requirements.ts.
  completionRequirementsJson Json?
  /// Snapshot of TaskDefinition.conditionalRulesJson frozen at activation.
  conditionalRulesJson       Json?
  /// Snapshot of TaskDefinition.instructions frozen at activation.
  instructions               String?

  changeOrderIdCreated    String?
  changeOrderIdSuperseded String?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  flow         Flow         @relation(fields: [flowId], references: [id], onDelete: Restrict)
  quoteVersion QuoteVersion @relation(fields: [quoteVersionId], references: [id], onDelete: Restrict)

  changeOrderCreated    ChangeOrder? @relation("RuntimeTaskCreatedByCO", fields: [changeOrderIdCreated], references: [id], onDelete: SetNull)
  changeOrderSuperseded ChangeOrder? @relation("RuntimeTaskSupersededByCO", fields: [changeOrderIdSuperseded], references: [id], onDelete: SetNull)

  holds Hold[]

  completionProofs CompletionProof[]

  taskExecutions TaskExecution[]

  @@unique([flowId, packageTaskId])
  @@index([tenantId])
  @@index([flowId])
}

model Quote {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  flowGroupId String
  /// When set, this shell was created from lead conversion (Epic 01 / Epic 07). Application wiring comes in a later slice.
  leadId      String?
  quoteNumber String
  createdAt   DateTime @default(now())

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer  Customer       @relation(fields: [customerId], references: [id], onDelete: Restrict)
  flowGroup FlowGroup      @relation(fields: [flowGroupId], references: [id], onDelete: Restrict)
  lead      Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)
  versions  QuoteVersion[]

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([flowGroupId])
  @@index([tenantId, leadId])
}

model QuoteSignature {
  id                      String               @id @default(cuid())
  tenantId                String
  quoteVersionId          String               @unique
  method                  QuoteSignatureMethod
  signedAt                DateTime             @default(now())
  /// Office-recorded sign requires a tenant user; null when `method` is `CUSTOMER_PORTAL_ACCEPTED`.
  recordedById            String?
  /// Human-readable signer snapshot for portal acceptance (e.g. name + email).
  portalSignerLabel       String?
  /// Structured acceptance payload (legal toggles, etc.); optional for future templates.
  portalAcceptPayloadJson Json?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  quoteVersion QuoteVersion @relation(fields: [quoteVersionId], references: [id], onDelete: Restrict)
  recordedBy   User?        @relation("QuoteSignatureRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([tenantId])
}

model QuoteVersion {
  id                           String             @id @default(cuid())
  quoteId                      String
  versionNumber                Int
  status                       QuoteVersionStatus
  pinnedWorkflowVersionId      String?
  title                        String?
  createdAt                    DateTime           @default(now())
  createdById                  String
  sentAt                       DateTime?
  sentById                     String?
  sendClientRequestId          String?            @unique
  planSnapshotSha256           String?
  packageSnapshotSha256        String?
  generatedPlanSnapshot        Json?
  executionPackageSnapshot     Json?
  composePreviewStalenessToken String?
  /// Opaque customer portal link token; issued on first successful send (Epic 54).
  portalQuoteShareToken        String?            @unique
  signedAt                     DateTime?
  signedById                   String?

  quote                 Quote            @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  pinnedWorkflowVersion WorkflowVersion? @relation(fields: [pinnedWorkflowVersionId], references: [id], onDelete: Restrict)
  createdBy             User             @relation("QuoteVersionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  sentBy                User?            @relation("QuoteVersionSentBy", fields: [sentById], references: [id], onDelete: Restrict)
  signedBy              User?            @relation("QuoteVersionSignedBy", fields: [signedById], references: [id], onDelete: SetNull)
  voidedAt              DateTime?
  voidedById            String?
  voidReason            String?
  voidedBy              User?            @relation("QuoteVersionVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  /// Set when status becomes DECLINED via customer portal (Epic 13 + 54).
  portalDeclinedAt      DateTime?
  portalDeclineReason   String?          @db.Text
  proposalGroups        ProposalGroup[]
  quoteLineItems        QuoteLineItem[]
  auditEvents           AuditEvent[]
  quoteSignature        QuoteSignature?
  flow                  Flow?
  activation            Activation?
  runtimeTasks          RuntimeTask[]
  paymentGates          PaymentGate[]
  changeOrderDrafts     ChangeOrder[]    @relation("ChangeOrderDraftQuoteVersion")

  preJobTasks           PreJobTask[]
  quoteLocalPackets     QuoteLocalPacket[]
  portalShareDeliveries QuotePortalShareDelivery[]
  jobHandoffs           JobHandoff[]

  @@unique([quoteId, versionNumber])
  @@index([quoteId])
  @@index([status])
  @@index([pinnedWorkflowVersionId])
  @@index([signedById])
}

/// Epic 44 — single office-authored briefing per job; immutable core after acknowledge (MVP: no edit after ACK).
model JobHandoff {
  id             String @id @default(cuid())
  tenantId       String
  jobId          String @unique
  /// Activation quote version this handoff anchors to (same tenant/job; not a scope edit).
  quoteVersionId String

  status          JobHandoffStatus @default(DRAFT)
  briefingNotes   String?          @db.Text
  /// JSON string[] of `User.id` in this tenant; empty = any field role may acknowledge (MVP).
  assignedUserIds Json             @default("[]")

  createdByUserId      String
  sentAt               DateTime?
  sentByUserId         String?
  acknowledgedAt       DateTime?
  acknowledgedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  job            Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  quoteVersion   QuoteVersion @relation(fields: [quoteVersionId], references: [id], onDelete: Restrict)
  createdBy      User         @relation("JobHandoffCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  sentBy         User?        @relation("JobHandoffSentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)
  acknowledgedBy User?        @relation("JobHandoffAcknowledgedBy", fields: [acknowledgedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, status])
}

model QuoteLocalPacket {
  id                              String                    @id @default(cuid())
  tenantId                        String
  quoteVersionId                  String
  displayName                     String
  description                     String?
  originType                      QuoteLocalPacketOrigin
  forkedFromScopePacketRevisionId String?
  aiProvenanceJson                Json?
  promotionStatus                 QuoteLocalPromotionStatus @default(NONE)
  promotedScopePacketId           String?
  createdById                     String
  updatedById                     String?
  createdAt                       DateTime                  @default(now())
  updatedAt                       DateTime                  @updatedAt

  quoteVersion QuoteVersion         @relation(fields: [quoteVersionId], references: [id], onDelete: Cascade)
  forkedFrom   ScopePacketRevision? @relation("QuoteLocalPacketForkSource", fields: [forkedFromScopePacketRevisionId], references: [id], onDelete: SetNull)
  createdBy    User                 @relation("QuoteLocalPacketCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy    User?                @relation("QuoteLocalPacketUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  items                      QuoteLocalPacketItem[]
  lineItemsPinningThisPacket QuoteLineItem[]

  @@index([quoteVersionId])
  @@index([tenantId, quoteVersionId])
}

model QuoteLocalPacketItem {
  id                 String  @id @default(cuid())
  quoteLocalPacketId String
  lineKey            String
  sortOrder          Int
  tierCode           String?

  lineKind            QuoteLocalPacketLineKind
  embeddedPayloadJson Json?
  taskDefinitionId    String?

  /// Stable node key within QuoteVersion.pinned WorkflowVersion.snapshotJson (align with compose; see extension doc).
  targetNodeKey String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteLocalPacket QuoteLocalPacket @relation(fields: [quoteLocalPacketId], references: [id], onDelete: Cascade)
  taskDefinition   TaskDefinition?  @relation(fields: [taskDefinitionId], references: [id], onDelete: SetNull)

  @@unique([quoteLocalPacketId, lineKey])
  @@index([quoteLocalPacketId, sortOrder])
}

model ProposalGroup {
  id             String @id @default(cuid())
  quoteVersionId String
  name           String
  sortOrder      Int

  quoteVersion   QuoteVersion    @relation(fields: [quoteVersionId], references: [id], onDelete: Cascade)
  quoteLineItems QuoteLineItem[]

  @@index([quoteVersionId])
}

model QuoteLineItem {
  id                       String                     @id @default(cuid())
  quoteVersionId           String
  proposalGroupId          String
  sortOrder                Int
  scopePacketRevisionId    String?
  quoteLocalPacketId       String?
  tierCode                 String?
  quantity                 Int
  executionMode            QuoteLineItemExecutionMode
  title                    String
  description              String?
  unitPriceCents           Int?
  lineTotalCents           Int?
  /// When true, send/freeze derives `paymentGateIntent.v0` targeting manifest package slots for this line (Epic 47).
  paymentBeforeWork        Boolean                    @default(false)
  /// Optional gate title override (trimmed server-side); only consulted when `paymentBeforeWork` is true at send.
  paymentGateTitleOverride String?

  quoteVersion        QuoteVersion         @relation(fields: [quoteVersionId], references: [id], onDelete: Cascade)
  proposalGroup       ProposalGroup        @relation(fields: [proposalGroupId], references: [id], onDelete: Restrict)
  scopePacketRevision ScopePacketRevision? @relation(fields: [scopePacketRevisionId], references: [id], onDelete: Restrict)
  quoteLocalPacket    QuoteLocalPacket?    @relation(fields: [quoteLocalPacketId], references: [id], onDelete: Restrict)

  @@index([quoteVersionId])
  @@index([proposalGroupId])
  @@index([scopePacketRevisionId])
  @@index([quoteLocalPacketId])
}

model AuditEvent {
  id                   String         @id @default(cuid())
  tenantId             String
  eventType            AuditEventType
  actorId              String?
  targetQuoteVersionId String?
  targetFlowId         String?
  /// When set, row is queryable as **customer-scoped** system history (Epic 57).
  targetCustomerId     String?
  payloadJson          Json?
  createdAt            DateTime       @default(now())

  tenant             Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actor              User?         @relation(fields: [actorId], references: [id], onDelete: Restrict)
  targetQuoteVersion QuoteVersion? @relation(fields: [targetQuoteVersionId], references: [id], onDelete: Restrict)
  targetFlow         Flow?         @relation(fields: [targetFlowId], references: [id], onDelete: Restrict)
  targetCustomer     Customer?     @relation("AuditEventTargetCustomer", fields: [targetCustomerId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([targetQuoteVersionId])
  @@index([targetFlowId])
  @@index([tenantId, targetCustomerId, createdAt])
}

/// Office-applied operational pause on a job and optionally one manifest runtime task (Epic 29 backbone).
model Hold {
  id            String     @id @default(cuid())
  tenantId      String
  jobId         String
  /// Null = job-wide hold (blocks all runtime tasks on the job + skeleton starts on that job).
  runtimeTaskId String?
  holdType      HoldType   @default(OPERATIONAL_CUSTOM)
  status        HoldStatus @default(ACTIVE)
  reason        String     @db.Text
  createdById   String
  createdAt     DateTime   @default(now())
  releasedAt    DateTime?
  releasedById  String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  job         Job          @relation(fields: [jobId], references: [id], onDelete: Restrict)
  runtimeTask RuntimeTask? @relation(fields: [runtimeTaskId], references: [id], onDelete: Restrict)
  createdBy   User         @relation("HoldCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  releasedBy  User?        @relation("HoldReleasedBy", fields: [releasedById], references: [id], onDelete: SetNull)

  @@index([tenantId, jobId, status])
  @@index([tenantId, runtimeTaskId, status])
}

model PaymentGate {
  id             String            @id @default(cuid())
  tenantId       String
  jobId          String
  quoteVersionId String            @unique
  status         PaymentGateStatus @default(UNSATISFIED)
  title          String
  satisfiedAt    DateTime?
  satisfiedById  String?

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  job          Job                 @relation(fields: [jobId], references: [id], onDelete: Restrict)
  quoteVersion QuoteVersion        @relation(fields: [quoteVersionId], references: [id], onDelete: Restrict)
  satisfiedBy  User?               @relation("PaymentGateSatisfiedBy", fields: [satisfiedById], references: [id], onDelete: SetNull)
  targets      PaymentGateTarget[]

  @@index([tenantId])
  @@index([jobId])
}

model PaymentGateTarget {
  id            String                @id @default(cuid())
  paymentGateId String
  taskKind      TaskExecutionTaskKind
  taskId        String // Either skeletonTaskId or RuntimeTask.id

  paymentGate PaymentGate @relation(fields: [paymentGateId], references: [id], onDelete: Cascade)

  @@index([paymentGateId])
  @@index([taskId])
}

model ChangeOrder {
  id                  String            @id @default(cuid())
  tenantId            String
  jobId               String
  reason              String
  status              ChangeOrderStatus @default(DRAFT)
  draftQuoteVersionId String?           @unique
  appliedAt           DateTime?
  appliedById         String?
  createdById         String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  job               Job           @relation(fields: [jobId], references: [id], onDelete: Restrict)
  draftQuoteVersion QuoteVersion? @relation("ChangeOrderDraftQuoteVersion", fields: [draftQuoteVersionId], references: [id], onDelete: SetNull)
  createdBy         User          @relation("ChangeOrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  appliedBy         User?         @relation("ChangeOrderAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)

  addedTasks      RuntimeTask[] @relation("RuntimeTaskCreatedByCO")
  supersededTasks RuntimeTask[] @relation("RuntimeTaskSupersededByCO")

  @@index([tenantId])
  @@index([jobId])
}

model CompletionProof {
  id              String   @id @default(cuid())
  tenantId        String
  runtimeTaskId   String
  taskExecutionId String   @unique
  note            String?
  createdAt       DateTime @default(now())

  checklistJson    Json? // Array of { label: string, status: 'yes'|'no'|'na' }
  measurementsJson Json? // Array of { label: string, value: string, unit?: string }
  identifiersJson  Json? // Array of { label: string, value: string }
  overallResult    String? // e.g. "PASS", "FAIL"

  tenant        Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  runtimeTask   RuntimeTask                 @relation(fields: [runtimeTaskId], references: [id], onDelete: Restrict)
  taskExecution TaskExecution               @relation("TaskExecutionToCompletionProof", fields: [taskExecutionId], references: [id], onDelete: Restrict)
  attachments   CompletionProofAttachment[]

  @@index([tenantId])
  @@index([runtimeTaskId])
}

model CompletionProofAttachment {
  id                String   @id @default(cuid())
  tenantId          String
  completionProofId String
  storageKey        String
  fileName          String
  fileSize          Int
  contentType       String
  createdById       String
  createdAt         DateTime @default(now())

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  completionProof CompletionProof @relation(fields: [completionProofId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("CompletionProofAttachmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([completionProofId])
}

model ProjectShareDelivery {
  id              String                    @id @default(cuid())
  tenantId        String
  flowGroupId     String
  deliveredAt     DateTime                  @default(now())
  deliveredById   String
  deliveryMethod  PublicShareDeliveryMethod
  recipientDetail String? // Email or phone number
  shareToken      String // Snapshot of token at delivery time

  providerStatus     PublicShareDeliveryStatus @default(QUEUED)
  providerExternalId String?
  providerError      String?
  providerResponse   Json?
  retryCount         Int                       @default(0)

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  flowGroup   FlowGroup @relation(fields: [flowGroupId], references: [id], onDelete: Restrict)
  deliveredBy User      @relation(fields: [deliveredById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([flowGroupId])
}
